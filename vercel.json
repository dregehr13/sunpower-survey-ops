{
  "rewrites": [
    { "source": "/compose", "destination": "/compose/index.html" },
    { "source": "/compose/(.*)", "destination": "/compose/index.html" },
    { "source": "/queues", "destination": "/queues/index.html" },
    { "source": "/queues/(.*)", "destination": "/queues/index.html" }
  ],
  "headers": [
    {
      "source": "/lib/metrics.cjs",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    }
  ]
}
